-- ══════════════════════════════════════════
--  TUNE LOADER (same approach as reference)
-- ══════════════════════════════════════════

local Tune = nil

local function findTuneInModel(model)
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("ModuleScript") and (v.Name == "A-Chassis Tune" or v.Name == "Tune") then
            return v
        end
    end
    return nil
end

local function tryLoadFromSeat(seat)
    local current = seat.Parent
    while current and current ~= workspace do
        if current:IsA("Model") then
            local mod = findTuneInModel(current)
            if mod then
                local ok, result = pcall(require, mod)
                if ok and type(result) == "table" then
                    Tune = result
                    return true
                end
            end
        end
        current = current.Parent
    end
    return false
end

local function tryLoad()
    local char = LocalPlayer.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or not hum.SeatPart then return false end
    return tryLoadFromSeat(hum.SeatPart)
end

local function hookHumanoid(char)
    local hum = char:WaitForChild("Humanoid")
    hum:GetPropertyChangedSignal("SeatPart"):Connect(function()
        if hum.SeatPart and not Tune then
            if tryLoadFromSeat(hum.SeatPart) then
                Rayfield:Notify({
                    Title = "A-Chassis Modifier",
                    Content = "Vehicle detected! Tune loaded.",
                    Duration = 3,
                    Image = 4483362458,
                })
            end
        end
    end)
end

if not tryLoad() then
    Rayfield:Notify({
        Title = "A-Chassis Modifier",
        Content = "Sit in an A-Chassis vehicle to load the tuner.",
        Duration = 5,
        Image = 4483362458,
    })
    if LocalPlayer.Character then hookHumanoid(LocalPlayer.Character) end
    LocalPlayer.CharacterAdded:Connect(hookHumanoid)
end

-- ══════════════════════════════════════════
--  VEHICLE HELPERS
-- ══════════════════════════════════════════

local function getSeatPart()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return nil end
    local seat = hum.SeatPart
    if seat and seat:IsA("VehicleSeat") then return seat end
    return nil
end

local function getVehicleModel()
    local seat = getSeatPart()
    if not seat then return nil end
    local current = seat.Parent
    while current and current ~= workspace do
        if current:IsA("Model") then return current end
        current = current.Parent
    end
    return nil
end

local function isOnPoliceTeam()
    local team = LocalPlayer.Team
    return team and (team.Name == "Police" or team.Name == "police")
end

local function setValue(key, value)
    if not Tune then
        Rayfield:Notify({
            Title = "No Tune Loaded",
            Content = "Sit in an A-Chassis vehicle first.",
            Duration = 4,
            Image = 4483362458,
        })
        return
    end
    Tune[key] = value
    Rayfield:Notify({
        Title = "Applied",
        Content = key .. " -> " .. tostring(value),
        Duration = 2,
        Image = 4483362458,
    })
end

-- ══════════════════════════════════════════
--  SUSPENSION (direct SpringConstraint apply)
-- ══════════════════════════════════════════

local SuspData = {
    FSusStiffness = 15000, FSusDamping = 1100,
    FSusLength = 2.1,      FPreCompress = 0.3,
    FExtensionLim = 0.22,  FCompressLim = 0.20,
    RSusStiffness = 15000, RSusDamping = 1200,
    RSusLength = 2.1,      RPreCompress = 0.3,
    RExtensionLim = 0.23,  RCompressLim = 0.21,
}

local function applySusp(key, value)
    SuspData[key] = value
    local model = getVehicleModel()
    if not model then
        Rayfield:Notify({ Title="No Vehicle", Content="Sit in a vehicle first.", Duration=3, Image=4483362458 })
        return
    end
    if Tune then Tune[key] = value end

    local applied = 0
    for _, obj in ipairs(model:GetDescendants()) do
        if obj:IsA("SpringConstraint") then
            -- Determine which axle this spring is on by walking up its parent chain
            local isFront, isRear = false, false
            local p = obj
            for _ = 1, 6 do
                if p then
                    local n = p.Name:upper()
                    if n:sub(1,1) == "F" or n:find("FRONT") or n == "FL" or n == "FR" then isFront = true end
                    if n:sub(1,1) == "R" or n:find("REAR")  or n == "RL" or n == "RR" then isRear  = true end
                    p = p.Parent
                end
            end

            pcall(function()
                if key == "FSusStiffness" and isFront then obj.Stiffness = value applied = applied + 1
                elseif key == "RSusStiffness" and isRear  then obj.Stiffness = value applied = applied + 1
                elseif key == "FSusDamping"   and isFront then obj.Damping   = value applied = applied + 1
                elseif key == "RSusDamping"   and isRear  then obj.Damping   = value applied = applied + 1
                elseif (key == "FSusLength" or key == "FPreCompress") and isFront then
                    local fl = SuspData.FSusLength + SuspData.FPreCompress
                    obj.FreeLength = fl
                    obj.MaxLength  = fl + SuspData.FCompressLim
                    obj.MinLength  = math.max(0, fl - SuspData.FExtensionLim)
                    applied = applied + 1
                elseif (key == "RSusLength" or key == "RPreCompress") and isRear then
                    local rl = SuspData.RSusLength + SuspData.RPreCompress
                    obj.FreeLength = rl
                    obj.MaxLength  = rl + SuspData.RCompressLim
                    obj.MinLength  = math.max(0, rl - SuspData.RExtensionLim)
                    applied = applied + 1
                end
            end)
        end
    end

    if applied > 0 then
        Rayfield:Notify({ Title="Suspension", Content=key.." -> "..tostring(value).." ("..applied.." springs)", Duration=2, Image=4483362458 })
    else
        -- No springs found by axle name — apply stiffness/damping to ALL springs as fallback
        for _, obj in ipairs(model:GetDescendants()) do
            if obj:IsA("SpringConstraint") then
                pcall(function()
                    if key:find("Stiffness") then obj.Stiffness = value
                    elseif key:find("Damping") then obj.Damping = value
                    elseif key:find("Length") or key:find("Compress") then
                        local l = SuspData.FSusLength + SuspData.FPreCompress
                        obj.FreeLength = l
                        obj.MaxLength  = l + SuspData.FCompressLim
                        obj.MinLength  = math.max(0, l - SuspData.FExtensionLim)
                    end
                end)
                applied = applied + 1
            end
        end
        if applied > 0 then
            Rayfield:Notify({ Title="Suspension (all)", Content=key.." -> "..tostring(value), Duration=2, Image=4483362458 })
        else
            Rayfield:Notify({ Title="Tune Only", Content=key.." set in tune (no springs found)", Duration=3, Image=4483362458 })
        end
    end
end

-- ══════════════════════════════════════════
--  AFK FARM TRACK (CLIENT SIDED, IN SKY)
-- ══════════════════════════════════════════

local TRACK_LENGTH       = 1500
local TRACK_BEHIND       = 200   -- studs of road behind spawn point
local TRACK_Y            = 500
local RUN_TIME           = 10

local trackFolder = nil
local trackOrigin = nil

local function buildTrack(origin)
    if trackFolder then trackFolder:Destroy() trackFolder = nil end

    trackFolder = Instance.new("Folder")
    trackFolder.Name = "AFK_Farm_Track"
    trackFolder.Parent = workspace

    local road = Instance.new("Part")
    road.Anchored = true road.CanCollide = true
    local totalLength = TRACK_LENGTH + TRACK_BEHIND
    road.Size = Vector3.new(14, 1, totalLength)
    road.CFrame = origin * CFrame.new(0, -1.5, -(TRACK_LENGTH / 2) + (TRACK_BEHIND / 2))
    road.Material = Enum.Material.SmoothPlastic
    road.BrickColor = BrickColor.new("Dark stone grey")
    road.Parent = trackFolder

    local sl = Instance.new("Part")
    sl.Anchored = true sl.CanCollide = false
    sl.Size = Vector3.new(14, 0.2, 1)
    sl.CFrame = origin * CFrame.new(0, -0.9, TRACK_BEHIND - 2)
    sl.Material = Enum.Material.Neon
    sl.BrickColor = BrickColor.new("Lime green")
    sl.Parent = trackFolder

    local el = Instance.new("Part")
    el.Anchored = true el.CanCollide = false
    el.Size = Vector3.new(14, 0.2, 1)
    el.CFrame = origin * CFrame.new(0, -0.9, -(TRACK_LENGTH - 2))
    el.Material = Enum.Material.Neon
    el.BrickColor = BrickColor.new("Bright red")
    el.Parent = trackFolder

    for _, side in ipairs({-7.5, 7.5}) do
        local b = Instance.new("Part")
        b.Anchored = true b.CanCollide = true
        b.Size = Vector3.new(1, 4, totalLength)
        b.CFrame = origin * CFrame.new(side, 0, -(TRACK_LENGTH / 2) + (TRACK_BEHIND / 2))
        b.Material = Enum.Material.Concrete
        b.BrickColor = BrickColor.new("White")
        b.Parent = trackFolder
    end

    local ew = Instance.new("Part")
    ew.Anchored = true ew.CanCollide = true
    ew.Size = Vector3.new(14, 4, 1)
    ew.CFrame = origin * CFrame.new(0, 0, -(TRACK_LENGTH + 1))
    ew.BrickColor = BrickColor.new("Bright red")
    ew.Parent = trackFolder

    trackOrigin = origin
end

local function removeTrack()
    if trackFolder then trackFolder:Destroy() trackFolder = nil end
    trackOrigin = nil
end

local function teleportVehicleToStart()
    local model = getVehicleModel()
    if not model then return false end
    local pp = model.PrimaryPart
    if not pp then return false end
    model:SetPrimaryPartCFrame(trackOrigin * CFrame.new(0, 4, -(TRACK_BEHIND - 10)))
    task.wait(0.6)
    return true
end

-- ══════════════════════════════════════════
--  AFK FARM LOOP
-- ══════════════════════════════════════════

local farmRunning    = false
local farmThread     = nil
local driveConn      = nil
local DRIVE_SPEED    = 30 * 1.467  -- 30 mph in studs/s

local function startDriving()
    -- Every heartbeat, push the vehicle forward at 30 mph via AssemblyLinearVelocity
    driveConn = RunService.Heartbeat:Connect(function()
        local model = getVehicleModel()
        if not model then return end
        local pp = model.PrimaryPart
        if not pp then return end
        local look = pp.CFrame.LookVector
        local flat = Vector3.new(look.X, 0, look.Z).Unit
        pp.AssemblyLinearVelocity = flat * DRIVE_SPEED
    end)
end

local function stopDriving()
    if driveConn then
        driveConn:Disconnect()
        driveConn = nil
    end
    -- Zero out velocity so car stops cleanly
    local model = getVehicleModel()
    if model and model.PrimaryPart then
        model.PrimaryPart.AssemblyLinearVelocity = Vector3.zero
    end
end

local function runFarmLoop()
    while farmRunning do
        if not isOnPoliceTeam() then
            Rayfield:Notify({ Title="AFK Farm", Content="Must be on Police team!", Duration=3, Image=4483362458 })
            task.wait(3)
        else
            local seat = getSeatPart()
            if not seat then
                Rayfield:Notify({ Title="AFK Farm", Content="Not in a vehicle. Waiting...", Duration=3, Image=4483362458 })
                task.wait(3)
            else
                -- Build track first time
                if not trackOrigin then
                    local pos  = seat.Position
                    local look = Vector3.new(seat.CFrame.LookVector.X, 0, seat.CFrame.LookVector.Z).Unit
                    local skyPos = Vector3.new(pos.X, TRACK_Y, pos.Z)
                    buildTrack(CFrame.lookAt(skyPos, skyPos + look))
                    Rayfield:Notify({ Title="AFK Farm", Content="Track built at Y=500. Starting...", Duration=3, Image=4483362458 })
                    task.wait(0.5)
                end

                -- Teleport to start then drive
                if not teleportVehicleToStart() then task.wait(2) continue end
                task.wait(0.3)

                startDriving()
                task.wait(RUN_TIME)
                stopDriving()
                task.wait(0.2)
            end
        end
    end

    stopDriving()
    removeTrack()
    Rayfield:Notify({ Title="AFK Farm", Content="Stopped. Track removed.", Duration=3, Image=4483362458 })
end

