            task.wait(0.3)

            -- VirtualInputManager click to activate item (working reference approach)
            local vim = game:GetService('VirtualInputManager')
            local startClick = tick()
            repeat
                vim:SendMouseButtonEvent(0, 8, 0, true, nil, 1)
                task.wait(0.05)
            until LocalPlayer.PlayerGui:FindFirstChild('DialogueGui') or tick() - startClick > 3

            local gui = LocalPlayer.PlayerGui:FindFirstChild('DialogueGui')
            if gui then
                local frame = gui:FindFirstChild('Frame')
                local opt = frame and frame:FindFirstChild('Options') and frame.Options:FindFirstChild('Option1')
                if opt and opt:FindFirstChild('TextButton') then
                    for _, c in pairs(getconnections(opt.TextButton.MouseButton1Click)) do c:Fire() end
                end
            end

            -- wait up to 10s for stand (working reference approach)
            local startWait = tick()
            while tick() - startWait < 10 do
                if LocalPlayer.PlayerStats.Stand.Value ~= 'None' then break end
                task.wait(0.1)
            end
        end
    end

