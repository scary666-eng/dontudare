    -- solved: u115 = fetch and hop to a new server
    local function fetchAndHopServer()
        local serverData
        if serverCursor ~= '' then
            serverData = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceId .. '/servers/Public?sortOrder=' .. sortOrder .. '&limit=100&cursor=' .. serverCursor))
        else
            serverData = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceId .. '/servers/Public?sortOrder=' .. sortOrder .. '&limit=100'))
        end
        if serverData.nextPageCursor and serverData.nextPageCursor ~= 'null' and serverData.nextPageCursor ~= nil then
            serverCursor = serverData.nextPageCursor
        end
        local loopCount = 0
        for _, server in pairs(serverData.data) do
            local canHop   = true
            local serverId = tostring(server.id)
            if tonumber(server.maxPlayers) > tonumber(server.playing) then
                for _, blocked in pairs(serverBlockList) do
                    if loopCount == 0 then
                        if tonumber(currentHour) ~= tonumber(blocked) then
                            pcall(function()
                                delfile('VantaAutoPres3ServerBlocker.json')
                                serverBlockList = {}
                                table.insert(serverBlockList, currentHour)
                            end)
                        end
                    elseif serverId == tostring(blocked) then
                        canHop = false
                    end
                    loopCount = loopCount + 1
                end
                if canHop then
                    table.insert(serverBlockList, serverId)
                    task.wait()
                    pcall(function()
                        writefile('VantaAutoPres3ServerBlocker.json', game:GetService('HttpService'):JSONEncode(serverBlockList))
                        task.wait()
                        game:GetService('TeleportService'):TeleportToPlaceInstance(PlaceId, serverId, LocalPlayer)
                    end)
                    task.wait(4)
                end
            end
        end
    end

