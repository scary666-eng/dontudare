    -- solved: u147 = collect a single item spawn by index
    local function collectItemSpawn(spawnData, index)
        local collected = false
        local timeout   = waitUntilCollect + 5
        if Character:FindFirstChild('SummonedStand') and Character.SummonedStand.Value then
            RemoteFunction:InvokeServer('ToggleStand', 'Toggle')
        end
        LocalPlayer.Backpack.ChildAdded:Connect(function()
            collected = true
        end)
        task.spawn(function()
            while not collected do
                task.wait()
                LocalPlayer.Character.HumanoidRootPart.CFrame = spawnData.Position[index] - Vector3.new(0, 10, 0)
            end
        end)
        task.wait(waitUntilCollect)
        task.spawn(function()
            fireproximityprompt(spawnData.ProximityPrompt[index])
            local gui = LocalPlayer.PlayerGui:WaitForChild('ScreenGui', 5)
            if gui then
                local part = gui:WaitForChild('Part')
                for _, btn in pairs(part:GetDescendants()) do
                    if btn:FindFirstChild('Part') and btn:IsA('ImageButton') and btn:WaitForChild('Part').TextColor3 == Color3.new(0, 1, 0) then
                        repeat
                            firesignal(btn.MouseEnter)
                            firesignal(btn.MouseButton1Up)
                            firesignal(btn.MouseButton1Click)
                            firesignal(btn.Activated)
                            task.wait()
                        until not LocalPlayer.PlayerGui:FindFirstChild('ScreenGui')
                    end
                end
            end
        end)
        task.spawn(function()
            for _ = timeout, 1, -1 do task.wait(1) end
            if not collected then collected = true end
        end)
        while not collected do task.wait() end
    end

    -- solved: u156 = collect items until have enough
    local function collectUntilHaveEnough(itemName, needed)
        local spawnData  = findItemSpawns(itemName)
