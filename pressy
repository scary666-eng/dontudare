        for idx, _ in pairs(spawnData.Position) do
            if countInBackpack(itemName) == needed or alreadyHas then
                print('SUCCESSFULLY BROKE')
                break
            end
            collectItemSpawn(spawnData, idx)
        end
        return true
    end

