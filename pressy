                LocalPlayer.Character.Humanoid:EquipTool(LocalPlayer.Backpack:FindFirstChild("Zeppeli's Hat"))
                LocalPlayer.Character.RemoteEvent:FireServer('PromptTriggered', game.ReplicatedStorage.NewDialogue:FindFirstChild('Lisa Lisa'))
                repeat game:GetService('VirtualInputManager'):SendMouseButtonEvent(0,8,0,true,nil,1) task.wait(0.05) until LocalPlayer.PlayerGui:FindFirstChild('DialogueGui')
                repeat game:GetService('VirtualInputManager'):SendMouseButtonEvent(0,8,0,true,nil,1) task.wait(0.05) until LocalPlayer.PlayerGui:FindFirstChild('DialogueGui').Frame.Options:FindFirstChild('Option1')
                firesignal(LocalPlayer.PlayerGui:FindFirstChild('DialogueGui').Frame.Options.Option1.TextButton.MouseButton1Click)
                repeat firesignal(LocalPlayer.PlayerGui:FindFirstChild('DialogueGui').Frame.ClickContinue.MouseButton1Click) task.wait(0.05) until LocalPlayer.PlayerGui:FindFirstChild('DialogueGui').Frame.Options:FindFirstChild('Option1')
                firesignal(LocalPlayer.PlayerGui:FindFirstChild('DialogueGui').Frame.Options.Option1.TextButton.MouseButton1Click)
                repeat firesignal(LocalPlayer.PlayerGui:FindFirstChild('DialogueGui').Frame.ClickContinue.MouseButton1Click) task.wait(0.05) until LocalPlayer.PlayerGui:FindFirstChild('DialogueGui').Frame.Options:FindFirstChild('Option1')
                firesignal(LocalPlayer.PlayerGui:FindFirstChild('DialogueGui').Frame.Options.Option1.TextButton.MouseButton1Click)
                task.wait(10)
                mainQuestLoop()
            else
                serverHop()
            end
            return
        end

        -- wait for 2 active quests
        while #Quests:GetChildren() < 2 and loopCount < 1000 do
            if not autoPrestEnabled then return end
            if not Quests:FindFirstChild('Take down 3 vampires') then
                notify('Quest timer: ' .. (tick() - questTimerStart) .. 's')
                questTimerStart = tick()
                fireDialogue('William Zeppeli', 'Dialogue4', 'Option1')
            end
            LocalPlayer.QuestsRemoteFunction:InvokeServer({'ReturnData'})
            fireStorylineDialogues()
            task.wait(0.01)
            loopCount = loopCount + 1
        end

        if loopCount >= 1000 then serverHop() return end

        -- quest dispatch
        if Quests:FindFirstChild('Help Giorno by Defeating Security Guards') then
            print('SECURITY GUARD')
            notify('Killing Security Guard ' .. LocalPlayer.PlayerStats.QuestProgress.Value .. '/' .. LocalPlayer.PlayerStats.QuestMaxProgress.Value)
            if killNPC('Security Guard', 15) then
                task.wait(1) fireStorylineDialogues() mainQuestLoop()
            else
                mainQuestLoop()
            end

        elseif standList[LocalPlayer.PlayerStats.Stand.Value] or (LocalPlayer.PlayerStats.Level.Value < 3 or not hasValidStand) then

            if Quests:FindFirstChild('Defeat Leaky Eye Luca') and standList[LocalPlayer.PlayerStats.Stand.Value] then
                print('LEAKY EYE LUCA')
                notify('Killing Leaky Eye Luca')
                if killNPC('Leaky Eye Luca', 15) then task.wait(1) fireStorylineDialogues() mainQuestLoop() else mainQuestLoop() end

            elseif Quests:FindFirstChild('Defeat Bucciarati') then
                print('BUCCIARATI')
                notify('Killing Bucciarati')
                if killNPC('Bucciarati', 15) then task.wait(1) fireStorylineDialogues() mainQuestLoop() else mainQuestLoop() end

            elseif Quests:FindFirstChild("Collect $5,000 To Cover For Popo's Real Fortune") then
                if LocalPlayer.PlayerStats.Money.Value < 5000 then
                    notify('Collecting $5000')
                    local function sellForMoney(name, amount)
                        if countInBackpack(name) <= amount then
                            collectUntilHaveEnough(name, amount)
                            Character.Humanoid:EquipTool(LocalPlayer.Backpack:FindFirstChild(name))
                            fireDialogue('Merchant', 'Dialogue5', 'Option2')
                            fireStorylineDialogues()
                            mainQuestLoop()
                        end
                        if LocalPlayer.PlayerStats.Money.Value < 5000 then
                            fireStorylineDialogues() mainQuestLoop()
                        end
                    end
                    task.wait(10)
                    sellForMoney('Mysterious Arrow', 25) sellForMoney('Rokakaka', 25)
                    sellForMoney('Diamond', 10)          sellForMoney('Steel Ball', 10)
                    sellForMoney("Quinton's Glove", 10)  sellForMoney('Pure Rokakaka', 10)
                    sellForMoney("Ribcage Of The Saint's Corpse", 10)
                    sellForMoney('Ancient Scroll', 10)   sellForMoney('Clackers', 10)
                    sellForMoney("Caesar's headband", 10)
                end
                mainQuestLoop()

            elseif Quests:FindFirstChild('Defeat Fugo And His Purple Haze') then
                print('FUGO')
                notify('Killing Fugo')
                if killNPC('Fugo', 15) then task.wait(1) fireStorylineDialogues() mainQuestLoop() else mainQuestLoop() end

            elseif Quests:FindFirstChild('Defeat Pesci') then
                print('PESCI')
                notify('Killing Pesci')
                if killNPC('Pesci', 15) then task.wait(1) fireStorylineDialogues() mainQuestLoop() else mainQuestLoop() end

            elseif Quests:FindFirstChild('Defeat Ghiaccio') then
                print('GHIACCIO')
                notify('Killing Ghiaccio')
                if killNPC('Ghiaccio', 15) then task.wait(1) fireStorylineDialogues() mainQuestLoop() else mainQuestLoop() end

            elseif Quests:FindFirstChild('Defeat Diavolo') then
                notify('Killing Diavolo')
                killNPC('Diavolo', 15)
                fireDialogue('Storyline #14', 'Dialogue7', 'Option1')
                if Character:WaitForChild('Requiem Arrow', 5) then
                    LocalPlayer.Character.Humanoid.Health = 0
                    serverHop()
                else
                    mainQuestLoop()
                end

            elseif LocalPlayer.PlayerStats.Level.Value ~= 50 then
                if Quests:FindFirstChild('Take down 3 vampires')
                and LocalPlayer.PlayerStats.Spec.Value ~= 'None'
                and LocalPlayer.PlayerStats.Level.Value >= 25
                and LocalPlayer.PlayerStats.Level.Value ~= 50 then
                    HamonCharge = 10
                    killNPC('Vampire', 15, false, function()
                        LocalPlayer.Character.PrimaryPart.CFrame = workspace.Living:FindFirstChild('Vampire').HumanoidRootPart.CFrame - Vector3.new(0, 15, 0)
                        if not Quests:FindFirstChild('Take down 3 vampires') then
                            if tick() - questTimerStart >= 5 then
                                notify('Vampire quest done in ' .. (tick() - questTimerStart) .. 's')
                                questTimerStart = tick()
                            end
                            fireDialogue('William Zeppeli', 'Dialogue4', 'Option1')
                        end
                    end)
                    mainQuestLoop()
                elseif LocalPlayer.PlayerStats.Level.Value == 50 then
                    if Character:FindFirstChild('FocusCam') then Character.FocusCam:Destroy() end
                    notify('Prestige 3, Level 50 reached! Stand: ' .. LocalPlayer.PlayerStats.Stand.Value)
                    pcall(function() delfile('VantaAutoPres3_' .. LocalPlayer.Name .. '.txt') end)
                end

            elseif Character:FindFirstChild('FocusCam') then
                Character.FocusCam:Destroy()
                notify('Prestige 3, Level 50 reached! Stand: ' .. LocalPlayer.PlayerStats.Stand.Value)
                pcall(function() delfile('VantaAutoPres3_' .. LocalPlayer.Name .. '.txt') end)
            end

        else
            print('NO STAND?')
            task.wait(5)
            collectUntilHaveEnough('Rokakaka', 25)
            collectUntilHaveEnough('Mysterious Arrow', 25)
            collectUntilHaveEnough("Zeppeli's Hat", 1)
            if countInBackpack('Mysterious Arrow') < 25 then
                serverHop()
            else
                print('MAX ARROW AND ROKA, ATTEMPTING STAND FARM')
                hasValidStand = false
                getOrClearStand()
            end
        end
    end

    -- prestige watcher (solved: task.spawn every 3s checking u182)
    task.spawn(function()
        while autoPrestEnabled do
            task.wait(3)
            if checkAndPrestige(LocalPlayer.PlayerStats.Level.Value, LocalPlayer.PlayerStats.Prestige.Value) then
                print('Prestiged')
                serverHop()
            elseif LocalPlayer.PlayerStats.Level.Value ~= 50 then
                print('not able to prestige yet')
            elseif not Character:FindFirstChild('FocusCam') then
                if Character:FindFirstChild('FocusCam') then Character.FocusCam:Destroy() end
                break
            end
        end
    end)

    -- respawn handler (solved: workspace.Living.ChildAdded)
    workspace.Living.ChildAdded:Connect(function(child)
        if child.Name == LocalPlayer.Name then
            if LocalPlayer.PlayerStats.Level.Value ~= 50 then
                if hasValidStand then serverHop() else getOrClearStand() end
            else
                print('didnt reconnect')
            end
        end
    end)

    -- level up notifier
    LocalPlayer.PlayerStats.Level:GetPropertyChangedSignal('Value'):Connect(function()
        notify('Level up! L' .. LocalPlayer.PlayerStats.Level.Value .. ' P' .. LocalPlayer.PlayerStats.Prestige.Value)
    end)

    -- disable collisions on respawn
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1)
        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA('BasePart') and part.CanCollide == true then
                part.CanCollide = false
            end
        end
    end)

    -- hook raycast
    hookfunction(workspace.Raycast, function() end)

    -- HUD setup
    if not LocalPlayer.PlayerGui:FindFirstChild('HUD') then
        game:GetService('ReplicatedStorage').Objects.HUD:Clone().Parent = LocalPlayer.PlayerGui
    end
    RemoteEvent:FireServer('PressedPlay')
    if LocalPlayer.PlayerGui:FindFirstChild('LoadingScreen1') then LocalPlayer.PlayerGui.LoadingScreen1:Destroy() end
    if LocalPlayer.PlayerGui:FindFirstChild('LoadingScreen')  then LocalPlayer.PlayerGui.LoadingScreen:Destroy()  end
    task.spawn(function()
        if game.Lighting:WaitForChild('DepthOfField', 10) then game.Lighting.DepthOfField:Destroy() end
    end)
    pcall(function()
        workspace.Map.IMPORTANT.OceanFloor.OceanFloor_Sand_6.Size = Vector3.new(2048, 89, 2048)
        workspace.Map.IMPORTANT.OceanFloor.OceanFloor_Sand_4.Size = Vector3.new(2048, 89, 2048)
    end)

    -- start
    if LocalPlayer.PlayerStats.Level.Value ~= 50 then
        mainQuestLoop()
    else
        while true do
            print('Level 50, Auto pres disabled')
            task.wait(9999999)
        end
    end

end -- end runAutoPrestige
