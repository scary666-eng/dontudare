local function GetPing()
return LocalPlayer:GetNetworkPing()
end

local function IsTimeStop()
return Workspace:FindFirstChild("TimeStop") or game.Lighting:FindFirstChild("TimeStop")
end

local function IsRagdolled(character)
if not character then return false end
return character:FindFirstChild("RagdollParts") and true or false
end

local function GetCharacter()
return LocalPlayer.Character
end

local function GetHRP()
local char = GetCharacter()
return char and char:FindFirstChild("HumanoidRootPart")
end

local function IsInRange(position, range)
local hrp = GetHRP()
if not hrp then return false end
return (position - hrp.Position).Magnitude <= range
end

local function Block()
local char = GetCharacter()
if not char then return end
local blockingCap = char:FindFirstChild("Blocking_Capacity")
if blockingCap and blockingCap.Value <= 0 then
State.Blocking = true
local remote = char:FindFirstChild("RemoteEvent")
if remote then
for i = 1, 3 do
remote:FireServer("StartBlocking", "pass")
task.wait()
end
end
end
end

local function Unblock(forced, instant)
if not Config.Unblocking and not forced then return end
if forced and not Config.Reblocking and not IsRagdolled(GetCharacter()) then return 42 end

local char = GetCharacter()
if not char then return end

if not (forced or instant) and State.FKeyHeld and Config.KeepBlock and not IsRagdolled(char) then
return
end

local remote = char:FindFirstChild("RemoteEvent")
if remote then
for i = 1, 5 do
remote:FireServer("StopBlocking", "pass")
task.wait()
end
end

State.Blocking = false
State.BlockActions = false
logUnblock(forced and "forced" or "auto-release")
end

local function RequestBlock(defense, waitTime, addWait, isPerfect, priority, isStandAttack, _logReason, _logDist)
if not Config.Enabled then return end
if State.BlockActions then
local currentPrio = tonumber(State.BlockActions) or 0
if priority and priority <= currentPrio then return end
end

State.BlockActions = priority or true

local char = GetCharacter()
if not char then return end

local remote = char:FindFirstChild("RemoteEvent")
if remote then
remote:FireServer("HoldAttack", {Bool = false, Type = "m1"})
end

State.LastBlock = State.LastBlock + 1
local currentBlock = State.LastBlock

local blockingCap = char:FindFirstChild("Blocking_Capacity")
if blockingCap and blockingCap.Value > 0 and isPerfect then
if defense < 0.2 or not Config.Reblocking then return end
if Unblock(true) == 42 then return end
end

local pingComp = Config.PingCompensation and GetPing() or 0
local actualWait = math.max(0, defense - pingComp)

if waitTime and waitTime > actualWait then
actualWait = waitTime
end

if Config.ExtraDelayEnabled then
actualWait = actualWait + Config.ExtraDelayAmount
end

if isStandAttack and Config.StandDelay > 0 then
actualWait = actualWait + Config.StandDelay
end

local scheduledClock = os.date("%H:%M:%S", os.time() + math.floor(actualWait))
local distStr = _logDist and string.format(" | dist=%.1f", _logDist) or ""
log(string.format("Scheduling block in %.3f s -> %s | %s%s", actualWait, scheduledClock, _logReason or "unknown", distStr))

task.wait(actualWait)

if State.LastBlock ~= currentBlock then return end
if IsTimeStop() then
State.BlockActions = false
return
end

logBlock(_logReason or "unknown", _logDist)

Block()

local unblockDelay = 0.4 + math.max(0.1, GetPing()) + (addWait or 0)
task.wait(unblockDelay)

if State.LastBlock == currentBlock and not IsTimeStop() then
State.BlockActions = false
Unblock(false)
end
end

local function ProcessBlockTrigger(source, parent, secondaryPart)
if not Config.Enabled then return end
if IsTimeStop() then return end
if IsRagdolled(GetCharacter()) then return end
if State.BlockProcsUntil > tick() then return end

local isPerfect = false
local defense = 0.4
local addWait = 0
local priority = 0
local distance = Config.BlockRange
local found = false
local extraWait = 0
local isStandAttack = false
local triggerReason = "unknown"

local function checkDistance(maxDist)
local hrp = GetHRP()
if not hrp then return false, 0 end

local targetPos = secondaryPart and secondaryPart.Position or parent.Position
local dist = (hrp.Position - targetPos).Magnitude

if dist > maxDist then
if secondaryPart then
dist = (hrp.Position - parent.Position).Magnitude
if dist > maxDist then return false, dist end
else
return false, dist
end
end

if dist > maxDist * Config.DistanceThreshold then
extraWait = Config.FarTargetDelay
task.wait(extraWait)
hrp = GetHRP()
if not hrp then return false, dist end
dist = (hrp.Position - targetPos).Magnitude
if dist > maxDist then return false, dist end
end

return true, dist
end

if source:IsA("Sound") then
for _, blockData in ipairs(BlockDatabase.PerfectBlocks) do
