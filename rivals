local espEnabled      = false
local espBoxes        = {}
local espNames        = {}
local espHealthBars   = {}
local espTracers      = {}
local espShowBoxes    = true
local espShowNames    = true
local espShowHealth   = true
local espShowTracers  = false
local espTeamColor    = false

local function newDrawing(type, props)
    local d = Drawing.new(type)
    for k, v in pairs(props) do d[k] = v end
    return d
end

local function removeESPForPlayer(p)
    local name = p.Name
    if espBoxes[name]      then espBoxes[name]:Remove()      espBoxes[name]=nil      end
    if espNames[name]      then espNames[name]:Remove()      espNames[name]=nil      end
    if espHealthBars[name] then espHealthBars[name]:Remove() espHealthBars[name]=nil end
    if espTracers[name]    then espTracers[name]:Remove()    espTracers[name]=nil    end
end

Players.PlayerRemoving:Connect(removeESPForPlayer)

ESPTab:CreateSection("ESP Settings")

ESPTab:CreateToggle({
    Name = "ESP Enabled",
    CurrentValue = false,
    Callback = function(v)
        espEnabled = v
        if not v then
            for _, p in ipairs(Players:GetPlayers()) do
                removeESPForPlayer(p)
            end
        end
        Notify("ESP", v and "Enabled" or "Disabled", 3)
    end,
})

ESPTab:CreateToggle({ Name="Show Boxes",    CurrentValue=true,  Callback=function(v) espShowBoxes=v    end })
ESPTab:CreateToggle({ Name="Show Names",    CurrentValue=true,  Callback=function(v) espShowNames=v    end })
ESPTab:CreateToggle({ Name="Show Health",   CurrentValue=true,  Callback=function(v) espShowHealth=v   end })
ESPTab:CreateToggle({ Name="Show Tracers",  CurrentValue=false, Callback=function(v) espShowTracers=v  end })

RunService.RenderStepped:Connect(function()
    if not espEnabled then return end
    local cam = workspace.CurrentCamera

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")

        if not hrp or not hum then
            removeESPForPlayer(p)
            continue
        end

        local name = p.Name
        local topPos, topVis    = cam:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
        local botPos, botVis    = cam:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
        local visible = topVis or botVis
        local color = Color3.fromRGB(255, 60, 60)

        if visible then
            local boxH = math.abs(topPos.Y - botPos.Y)
            local boxW = boxH * 0.55
            local cx   = topPos.X

            -- Box
            if espShowBoxes then
                if not espBoxes[name] then
                    espBoxes[name] = newDrawing("Square", {
                        Visible=true, Color=color, Thickness=1.5,
                        Filled=false, Transparency=1
                    })
                end
                local b = espBoxes[name]
                b.Visible  = true
                b.Color    = color
                b.Size     = Vector2.new(boxW, boxH)
                b.Position = Vector2.new(cx - boxW/2, topPos.Y)
            elseif espBoxes[name] then espBoxes[name].Visible=false end

            -- Name
            if espShowNames then
                if not espNames[name] then
                    espNames[name] = newDrawing("Text", {
                        Visible=true, Color=Color3.new(1,1,1), Size=14,
                        Center=true, Outline=true, Font=2
                    })
                end
                local n = espNames[name]
                n.Visible  = true
                n.Text     = p.Name .. " [" .. math.floor(hum.Health) .. "]"
                n.Position = Vector2.new(cx, topPos.Y - 18)
            elseif espNames[name] then espNames[name].Visible=false end

            -- Health bar
            if espShowHealth then
                if not espHealthBars[name] then
                    espHealthBars[name] = newDrawing("Square", {
                        Visible=true, Filled=true, Transparency=1, Thickness=1
                    })
                end
                local hb = espHealthBars[name]
                local hpRatio = hum.Health / hum.MaxHealth
                hb.Visible  = true
                hb.Color    = Color3.fromRGB(math.floor(255*(1-hpRatio)), math.floor(255*hpRatio), 0)
                hb.Size     = Vector2.new(4, boxH * hpRatio)
                hb.Position = Vector2.new(cx - boxW/2 - 7, topPos.Y + boxH*(1-hpRatio))
            elseif espHealthBars[name] then espHealthBars[name].Visible=false end

            -- Tracer
            if espShowTracers then
                if not espTracers[name] then
                    espTracers[name] = newDrawing("Line", {
                        Visible=true, Color=color, Thickness=1, Transparency=1
                    })
                end
                local t = espTracers[name]
                t.Visible = true
                t.Color   = color
                t.From    = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y)
                t.To      = Vector2.new(cx, botPos.Y)
            elseif espTracers[name] then espTracers[name].Visible=false end
        else
            -- Off screen, hide
            if espBoxes[name]      then espBoxes[name].Visible=false      end
            if espNames[name]      then espNames[name].Visible=false       end
            if espHealthBars[name] then espHealthBars[name].Visible=false  end
            if espTracers[name]    then espTracers[name].Visible=false     end
        end
    end
end)

