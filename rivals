-- ─── KEYBINDS ─────────────────────────────────────────────────────────────────
-- B = toggle silent aim, H = toggle hitbox, N = cycle blatant aim target

-- Declare here so cycleTarget() and the blatant aim block share the same upvalue
local blatantAimEnabled = false
local blatantAimTarget  = nil

local targetList  = {}
local targetIndex = 1

local function refreshTargetList()
    targetList = getEnemies()
    targetIndex = 1
end

local function cycleTarget()
    refreshTargetList()
    if #targetList == 0 then
        Notify("Target", "No enemies found.", 3)
        return
    end
    targetIndex = (targetIndex % #targetList) + 1
    blatantAimTarget = targetList[targetIndex]
    Notify("Target", "Locked: " .. blatantAimTarget.Name .. " (" .. targetIndex .. "/" .. #targetList .. ")", 3)
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.B then
        silentAimEnabled = not silentAimEnabled
        Notify("Silent Aim", silentAimEnabled and "ON [B]" or "OFF [B]", 2)
    elseif input.KeyCode == Enum.KeyCode.H then
        hitboxEnabled = not hitboxEnabled
        if not hitboxEnabled then restoreHitboxes() end
        Notify("Hitbox", hitboxEnabled and "ON [H]" or "OFF [H]", 2)
    elseif input.KeyCode == Enum.KeyCode.N then
        cycleTarget()
    end
end)

