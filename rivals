-- Hook the gun fire remote for silent aim
local function getTargetInFOV()
    local cam = workspace.CurrentCamera
    local center = Vector2.new(Mouse.X, Mouse.Y)
    local best, bestDist = nil, silentAimFOV
    for _, p in ipairs(getEnemies()) do
        local hrp = p.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local screenPos, inViewport = cam:WorldToViewportPoint(hrp.Position)
        if not inViewport then continue end
        local dist2D = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if dist2D < bestDist then
            bestDist = dist2D
            best = p
        end
    end
    return best
end

-- Global hook: intercepts fire:FireServer(Vector3) and replaces the aim position
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" and self.Name == "fire" and silentAimEnabled then
        local wsChar = workspace:FindFirstChild(LocalPlayer.Name)
        if wsChar and self:IsDescendantOf(wsChar) then
            local target = getTargetInFOV()
            if target and target.Character then
                local hrp = target.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    -- fire takes exactly one Vector3 — replace it entirely
                    return oldNamecall(self, hrp.Position)
                end
            end
        end
    end
    return oldNamecall(self, ...)
end)

-- ─── HITBOX EXPANSION ────────────────────────────────────────────────────────
local hitboxEnabled  = false
local hitboxSize     = 8
local hitboxOriginal = {} -- { [player.Name] = originalSize }

local function applyHitboxes()
    for _, p in ipairs(getEnemies()) do
        local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            if not hitboxOriginal[p.Name] then
                hitboxOriginal[p.Name] = hrp.Size
            end
            pcall(function() hrp.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize) end)
        end
    end
end

local function restoreHitboxes()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp and hitboxOriginal[p.Name] then
                hrp.Size = hitboxOriginal[p.Name]
            end
        end
    end
    hitboxOriginal = {}
end

