                if slash then pcall(function() slash:FireServer() end) end
            elseif wType == "Gun" then
                local fire = weapon:FindFirstChild("fire")
                if fire then pcall(function() fire:FireServer(myHRP.Position) end) end
            end

            task.wait(0.05)
            pcall(function() enemyHRP.CFrame = savedCFrame end)
        end
    end
end)

