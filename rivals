UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe or not teleportSlash then return end
    if input.KeyCode == Enum.KeyCode.Z then
        local myHRP = getHRP()
        if not myHRP then return end
        local nearest = getNearestEnemy()
        if not nearest then return end
        local targetHRP = nearest.Character.HumanoidRootPart
        local weapon, wType = getMyWeapon()
        -- TP to target, slash, TP back
        local origin = myHRP.CFrame
        myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 2.5)
        if weapon and wType == "Knife" then
            local slashEvt = weapon:FindFirstChild("Slash")
            if slashEvt then
                pcall(function() slashEvt:FireServer() end)
            end
        end
        task.wait(0.1)
        myHRP.CFrame = origin
    end
end)

