local function StopATMFarm()
    ATMRunning = false
    if ATMThread then
        task.cancel(ATMThread)
        ATMThread = nil
    end
    Notify({ Title = "ATM Farm", Content = "Stopped.", Duration = 3 })
end

local function RunATMPass(loop)
    local atms = GetATMData()
    if #atms == 0 then
        Notify({ Title = "ATM Farm", Content = "No ATMs found!", Duration = 4 })
        ATMRunning = false
        return
    end
    local startCash = GetCash()
    local cycle = 0

    while ATMRunning or (not loop) do
        cycle = cycle + 1
        for _, data in ipairs(atms) do
            if not ATMRunning and loop then break end
            if ATMTeleport then
                TeleportNearATM(data.attachment)
                task.wait(0.3)
            end
            pcall(function() fireproximityprompt(data.prompt) end)
            task.wait(ATMDelay)
        end
        local gained = math.floor(GetCash() - startCash)
        Notify({
            Title   = "ATM Farm — Cycle " .. cycle .. " Done",
            Content = "Session total: +$" .. gained .. " | Balance: $" .. math.floor(GetCash()),
            Duration = 3,
        })
        if not loop then break end
        task.wait(0.5)
    end
    ATMRunning = false
end

local function StartATMFarm()
    if ATMRunning then return end
    ATMRunning = true
    local atms = GetATMData()
    Notify({ Title = "ATM Farm", Content = "Started! Teleporting to " .. #atms .. " ATMs.", Duration = 4 })
    ATMThread = task.spawn(function() RunATMPass(true) end)
end

