-- Notification wrapper: plays success sound for every notification
local lastSoundTime = 0
local soundCooldown = 1.5
local function playSuccessSound()
    local now = tick()
    if now - lastSoundTime >= soundCooldown then
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxassetid://131527130925065"
        sound.Volume = 2
        sound.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
        sound:Play()
        task.spawn(function()
            task.wait(2)
            sound:Destroy()
        end)
        lastSoundTime = now
    end
end

local lastNotifyTime = 0
local notifyCooldown = 1.5
local function Notify(args)
    local now = tick()
    if now - lastNotifyTime >= notifyCooldown then
        playSuccessSound()
        WindUI:Notify(args)
        lastNotifyTime = now
    end
end
