local function T(tab, title, desc, tbl, key)
    return tab:Toggle({
        Title = title, Desc = desc,
        Icon = "check-square", Type = "Checkbox", Value = tbl[key],
        Callback = function(state) tbl[key] = state ApplyAll(Data) end,
    })
end

local function I(tab, title, desc, tbl, key, placeholder, notifyExtra)
    return tab:Input({
        Title = title, Desc = desc,
        InputIcon = "hash", Type = "Input",
        Value = tostring(tbl[key]),
        Placeholder = placeholder,
        Callback = function(input)
            local num = tonumber(input)
            if not num or num <= 0 then
                Notify({ Title = "Invalid Input", Content = "Enter a positive number.", Duration = 3 })
                return
            end
            local car = GetCar()
            if not car then
                Notify({ Title = "Vehicle Modifier", Content = "Sit in your car first!", Duration = 3 })
                return
            end
            tbl[key] = num
            ApplyAll(Data)
            Notify({
                Title   = title .. " set to " .. num,
                Content = notifyExtra or "Applied successfully.",
                Duration = 5,
            })
        end,
    })
end

