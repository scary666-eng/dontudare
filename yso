local function GetATMData()
    local list = {}
    local folder = workspace:FindFirstChild("Robberies") and workspace.Robberies:FindFirstChild("ATMs")
    if not folder then return list end
    for _, atm in ipairs(folder:GetChildren()) do
        local attachment = atm:FindFirstChild("ATMAttachment")
        if attachment and attachment:IsA("Attachment") then
            local prompt = attachment:FindFirstChild("ATMProximityPrompt")
            if prompt and prompt:IsA("ProximityPrompt") then
                table.insert(list, { prompt = prompt, attachment = attachment, model = atm })
            end
        end
    end
    return list
end

