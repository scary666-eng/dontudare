-- Fully functional raw speed modifier logic (Universal Vehicle Script)

local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local velocityEnabled = false -- Default OFF, controlled by toggle
local velocityMult = 0.025 -- Acceleration multiplier (W)
local velocityEnabledKeyCode = Enum.KeyCode.W
local velocityMult2 = 0.15 -- Brake multiplier (S)
local qbEnabledKeyCode = Enum.KeyCode.S
local stopKeyCode = Enum.KeyCode.P

ECUTab:Toggle({
    Title = "Enable Speed Modifier",
    Desc = "Toggle the raw speed modifier logic (W = accelerate, S = brake, P = stop)",
    Value = velocityEnabled,
    Callback = function(state)
        velocityEnabled = state
        WindUI:Notify({
            Title = "Speed Modifier",
            Content = state and "Speed modifier enabled!" or "Speed modifier disabled.",
            Duration = 3
        })
    end
})

RunService.Stepped:Connect(function()
    if not velocityEnabled then return end
    local Character = LocalPlayer.Character
    if Character and typeof(Character) == "Instance" then
        local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
        if Humanoid and typeof(Humanoid) == "Instance" then
            local SeatPart = Humanoid.SeatPart
            if SeatPart and typeof(SeatPart) == "Instance" and SeatPart:IsA("VehicleSeat") then
                -- Acceleration (W)
                if UserInputService:IsKeyDown(velocityEnabledKeyCode) then
                    SeatPart.AssemblyLinearVelocity *= Vector3.new(1 + velocityMult, 1, 1 + velocityMult)
                end
                -- Braking (S)
                if UserInputService:IsKeyDown(qbEnabledKeyCode) then
                    SeatPart.AssemblyLinearVelocity *= Vector3.new(1 - velocityMult2, 1, 1 - velocityMult2)
                end
                -- Stop vehicle (P)
                if UserInputService:IsKeyDown(stopKeyCode) then
                    SeatPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    SeatPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                end
            end
        end
    end
end)

