-- ── Universal Tune Finder ─────────────────────────────────────────────────────
-- Finds the A-Chassis Tune module from whatever vehicle the local player
-- is currently seated in. Works for any account, any game, any car.

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Tune = nil

local function findTuneInModel(model)
	for _, v in ipairs(model:GetDescendants()) do
		if v:IsA("ModuleScript") and (v.Name == "A-Chassis Tune" or v.Name == "Tune") then
			return v
		end
	end
	return nil
end

local function tryLoadFromSeat(seat)
	local current = seat.Parent
	while current and current ~= workspace do
		if current:IsA("Model") then
			local mod = findTuneInModel(current)
			if mod then
				Tune = require(mod)
				return true
			end
		end
		current = current.Parent
	end
	return false
end

local function tryLoad()
	local char = LocalPlayer.Character
	if not char then return false end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum or not hum.SeatPart then return false end
	return tryLoadFromSeat(hum.SeatPart)
end

if not tryLoad() then
	Rayfield:Notify({
		Title = "A-Chassis Modifier",
		Content = "Sit in an A-Chassis vehicle to load the tuner.",
		Duration = 5,
		Image = 4483362458,
	})

	local function hookHumanoid(char)
		local hum = char:WaitForChild("Humanoid")
		hum:GetPropertyChangedSignal("SeatPart"):Connect(function()
			if hum.SeatPart and not Tune then
				if tryLoadFromSeat(hum.SeatPart) then
					Rayfield:Notify({
						Title = "A-Chassis Modifier",
						Content = "Vehicle detected! Tune loaded.",
						Duration = 3,
						Image = 4483362458,
					})
				end
			end
		end)
	end

	if LocalPlayer.Character then
		hookHumanoid(LocalPlayer.Character)
	end
	LocalPlayer.CharacterAdded:Connect(hookHumanoid)

	repeat task.wait(0.2) until Tune ~= nil
end


