local function GetCar()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.SeatPart then return hum.SeatPart:FindFirstAncestorOfClass("Model") end
    local vehicles = workspace:FindFirstChild("Vehicles")
    if vehicles then
        for _, m in ipairs(vehicles:GetChildren()) do
            if m:IsA("Model") and m:GetAttribute("Owner") == LocalPlayer.Name then return m end
        end
    end
    return nil
end

local function GetTune()
    local car = workspace:FindFirstChild("Vehicles") and workspace.Vehicles:FindFirstChild(LocalPlayer.Name.."'s Vehicle")
    if not car then return nil end
    local tune = car:FindFirstChild("A-Chassis Tune")
    if not tune then return nil end
    local ok, module = pcall(require, tune)
    if ok and module then return module end
    return nil
end

local function SetEngineValue(car, key, value)
    local eng = car:FindFirstChild("Tuning") and car.Tuning:FindFirstChild("Engine")
    if eng and eng:FindFirstChild(key) then eng[key].Value = value end
end

local function SetTireValue(car, axle, key, value)
    local side = car:FindFirstChild("Tuning") and car.Tuning:FindFirstChild("Tires") and car.Tuning.Tires:FindFirstChild(axle)
    if side and side:FindFirstChild(key) then side[key].Value = value end
end

local function ApplySuspension(car, susp)
    local wheels = car:FindFirstChild("Wheels")
    if not wheels then return end
    for key, value in pairs(susp) do car:SetAttribute(key, value) end
    for _, wName in ipairs({"FL","FR"}) do
        local geo = wheels:FindFirstChild(wName) and wheels[wName]:FindFirstChild("SuspensionGeometry")
        if geo then
            local spring = geo:FindFirstChild("Spring")
            if spring and spring:IsA("SpringConstraint") then
                spring.Stiffness  = susp.FSusStiffness
                spring.Damping    = susp.FSusDamping
                spring.FreeLength = susp.FSusLength + susp.FSpacer
                spring.MaxLength  = susp.FSusLength + susp.FSpacer + susp.FCompressLim
                spring.MinLength  = math.max(0, susp.FSusLength + susp.FSpacer - susp.FExtensionLim)
            end
            local sway = geo:FindFirstChild("SwayBar")
            if sway and sway:IsA("SpringConstraint") then sway.Stiffness = susp.FSwayBar end
        end
    end
    for _, wName in ipairs({"RL","RR"}) do
        local geo = wheels:FindFirstChild(wName) and wheels[wName]:FindFirstChild("SuspensionGeometry")
        if geo then
            local spring = geo:FindFirstChild("Spring")
            if spring and spring:IsA("SpringConstraint") then
                spring.Stiffness  = susp.RSusStiffness
                spring.Damping    = susp.RSusDamping
                spring.FreeLength = susp.RSusLength + susp.RSpacer
                spring.MaxLength  = susp.RSusLength + susp.RSpacer + susp.RCompressLim
                spring.MinLength  = math.max(0, susp.RSusLength + susp.RSpacer - susp.RExtensionLim)
            end
            local sway = geo:FindFirstChild("SwayBar")
            if sway and sway:IsA("SpringConstraint") then sway.Stiffness = susp.RSwayBar end
        end
    end
end

local function ApplyEngine(car, engine)
    local torque = engine.Horsepower * 3.5
    SetEngineValue(car, "PeakTorque",    torque)
    SetEngineValue(car, "RedlineTorque", torque * 0.9)
    SetEngineValue(car, "Redline",       engine.Redline)
    local eng = car:FindFirstChild("Tuning") and car.Tuning:FindFirstChild("Engine")
    if eng then
        if eng:FindFirstChild("PeakRPM")    then eng.PeakRPM.Value    = 6300 end
        if eng:FindFirstChild("FinalDrive") then eng.FinalDrive.Value  = 3.9  end
    end
end

local function ApplyTires(car, tires)
    SetTireValue(car, "Front", "FFriction",       tires.FFriction)
    SetTireValue(car, "Front", "FFrictionWeight", tires.FFrictionWeight)
    SetTireValue(car, "Front", "FElasticity",     tires.FElasticity)
    SetTireValue(car, "Rear",  "RFriction",       tires.RFriction)
    SetTireValue(car, "Rear",  "RFrictionWeight", tires.RFrictionWeight)
    SetTireValue(car, "Rear",  "RElasticity",     tires.RElasticity)
end

local function ApplySteering(car, steer)
    for key, value in pairs(steer) do car:SetAttribute(key, value) end
end

