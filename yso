local function ApplyAll()
    local car = GetCar()
    if not car then Notify("Vehicle Modifier","No vehicle detected! Sit in your car.",4) return end
    ApplySuspension(car, Data.susp)
    ApplyEngine(car, Data.engine)
    ApplyTires(car, Data.tires)
    ApplySteering(car, Data.steer)
end

local function LoadFromCar()
    local car = GetCar()
    if not car then return end
    for key in pairs(Data.susp)  do local v=car:GetAttribute(key) if v~=nil then Data.susp[key]=v  end end
    for key in pairs(Data.steer) do local v=car:GetAttribute(key) if v~=nil then Data.steer[key]=v end end
    local tuning = car:FindFirstChild("Tuning")
    if tuning then
        local eng = tuning:FindFirstChild("Engine")
        if eng then
            local pt=eng:FindFirstChild("PeakTorque") local rl=eng:FindFirstChild("Redline")
            if pt and rl and rl.Value>0 then Data.engine.Redline=rl.Value Data.engine.Horsepower=math.floor((pt.Value*rl.Value)/5252) end
        end
        local tires=tuning:FindFirstChild("Tires")
        if tires then
            local front=tires:FindFirstChild("Front") local rear=tires:FindFirstChild("Rear")
            if front then for _,k in ipairs({"FFriction","FFrictionWeight","FElasticity"}) do if front:FindFirstChild(k) then Data.tires[k]=front[k].Value end end end
            if rear  then for _,k in ipairs({"RFriction","RFrictionWeight","RElasticity"}) do if rear:FindFirstChild(k)  then Data.tires[k]=rear[k].Value  end end end
        end
    end
end
