-- ─── VELOCITY / FLIGHT ────────────────────────────────────────────────────────

local function getSeatPart()
	local char = LocalPlayer.Character
	if not char then return nil end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return nil end
	local seat = hum.SeatPart
	if seat and seat:IsA("VehicleSeat") then return seat end
	return nil
end

local function getVehicleFromSeat(seat)
	local current = seat.Parent
	while current and current ~= workspace do
		if current:IsA("Model") then return current end
		current = current.Parent
	end
	return nil
end

-- State
local keybindsActive = false
local flightEnabled = false
local flightSpeed = 1
local velocityMult = 0.025
local velocityKeyCode = Enum.KeyCode.W
local brakeForce = 0.15
local brakeKeyCode = Enum.KeyCode.S

-- Flight loop
RunService.Stepped:Connect(function()
	if not flightEnabled then return end
	local seat = getSeatPart()
	if not seat then return end
	local vehicle = getVehicleFromSeat(seat)
	if not vehicle then return end
	if not vehicle.PrimaryPart then
		vehicle.PrimaryPart = seat
	end
	local cf = vehicle:GetPrimaryPartCFrame()
	local camLook = workspace.CurrentCamera.CFrame.LookVector
	local inp = UserInputService
	if not inp:GetFocusedTextBox() then
		vehicle:SetPrimaryPartCFrame(
			CFrame.new(cf.Position, cf.Position + camLook) * CFrame.new(
				(inp:IsKeyDown(Enum.KeyCode.D) and flightSpeed) or (inp:IsKeyDown(Enum.KeyCode.A) and -flightSpeed) or 0,
				(inp:IsKeyDown(Enum.KeyCode.E) and flightSpeed / 2) or (inp:IsKeyDown(Enum.KeyCode.Q) and -flightSpeed / 2) or 0,
				(inp:IsKeyDown(Enum.KeyCode.S) and flightSpeed) or (inp:IsKeyDown(Enum.KeyCode.W) and -flightSpeed) or 0
			)
		)
	end
	seat.AssemblyLinearVelocity = Vector3.zero
	seat.AssemblyAngularVelocity = Vector3.zero
end)

-- Velocity hold loop
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe or not keybindsActive then return end
	if input.KeyCode == velocityKeyCode then
		while UserInputService:IsKeyDown(velocityKeyCode) and keybindsActive do
			task.wait()
			local seat = getSeatPart()
			if seat then
				seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity * Vector3.new(1 + velocityMult, 1, 1 + velocityMult)
			end
		end
	elseif input.KeyCode == brakeKeyCode then
		while UserInputService:IsKeyDown(brakeKeyCode) and keybindsActive do
			task.wait()
			local seat = getSeatPart()
			if seat then
				seat.AssemblyLinearVelocity = seat.AssemblyLinearVelocity * Vector3.new(1 - brakeForce, 1, 1 - brakeForce)
			end
		end
	end
end)

