-- Force Entry Script
local forceEntryEnabled = false
local forceEntryThread = nil

MiscTab:Toggle({
    Title = "Force Entry (Drive Any Car)",
    Desc = "Rapidly attempts to sit in nearest vehicle seat.",
    Icon = "key",
    Type = "Checkbox",
    Value = false,
    Callback = function(state)
        forceEntryEnabled = state
        if state then
            Notify({ Title = "Force Entry", Content = "Force Entry enabled! Hold near a car.", Duration = 4 })
            if forceEntryThread == nil then
                forceEntryThread = task.spawn(function()
                    while forceEntryEnabled do
                        local char = LocalPlayer.Character
                        if char then
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            local hrp = char:FindFirstChild("HumanoidRootPart")
                            if hum and hrp and not hum.Sit then
                                local vehicles = workspace:FindFirstChild("Vehicles")
                                if vehicles then
                                    local closestSeat, closestDist = nil, math.huge
                                    for _, vehicle in ipairs(vehicles:GetChildren()) do
                                        if vehicle:IsA("Model") then
                                            for _, seat in ipairs(vehicle:GetDescendants()) do
                                                if seat:IsA("VehicleSeat") then
                                                    local dist = (seat.Position - hrp.Position).Magnitude
                                                    if dist < closestDist then
                                                        closestDist = dist
                                                        closestSeat = seat
                                                    end
                                                end
                                            end
                                        end
                                    end
                                    if closestSeat and closestDist <= 3 then
                                        hum.Sit = false
                                        closestSeat:Sit(hum)
                                    end
                                end
                            end
                        end
                        task.wait(0.05) -- spam fast, but not too fast
                    end
                    forceEntryThread = nil
                end)
            end
        else
            Notify({ Title = "Force Entry", Content = "Force Entry disabled.", Duration = 3 })
            forceEntryEnabled = false
            if forceEntryThread then
                task.cancel(forceEntryThread)
                forceEntryThread = nil
            end
        end
    end,
})


-- Lowrider Bounce Toggle
local lowriderToggle = false
local cycleState = 0
local originalSprings = {}

local function getPlayerCarWheels()
    local car = GetCar()
    if not car then return nil end
    return car:FindFirstChild("Wheels")
end

local function getFrontWheels()
    local wheels = getPlayerCarWheels()
    if not wheels then return {} end
    return { wheels:FindFirstChild("FL"), wheels:FindFirstChild("FR") }
end

local function storeOriginalSprings()
    originalSprings = {}
    for _, wheel in ipairs(getFrontWheels()) do
        if wheel then
            local geo = wheel:FindFirstChild("SuspensionGeometry")
            if geo then
                local spring = geo:FindFirstChild("Spring")
                if spring then
                    originalSprings[wheel.Name] = {
                        Stiffness = spring.Stiffness,
                        Damping = spring.Damping,
                        FreeLength = spring.FreeLength
                    }
                end
            end
        end
    end
end

local function animateWheelSet(wheels, freeLength)
    for _, wheel in ipairs(wheels) do
        if wheel then
            local geo = wheel:FindFirstChild("SuspensionGeometry")
            if geo then
                local spring = geo:FindFirstChild("Spring")
                if spring then
                    spring.FreeLength = freeLength
                end
            end
        end
    end
end

local function animateToOriginal()
    for _, wheel in ipairs(getFrontWheels()) do
        if wheel and originalSprings[wheel.Name] then
            local geo = wheel:FindFirstChild("SuspensionGeometry")
            if geo then
                local spring = geo:FindFirstChild("Spring")
                if spring then
                    local orig = originalSprings[wheel.Name]
                    spring.Stiffness = orig.Stiffness
                    spring.Damping = orig.Damping
                    spring.FreeLength = orig.FreeLength
                end
            end
        end
    end
end

MiscTab:Toggle({
    Title = "Lowrider Bounce",
    Desc = "Animate front suspension for lowrider effect. Only works on stock suspension (not modified by script).",
    Icon = "activity",
    Type = "Checkbox",
    Value = false,
    Callback = function(state)
        if state then
            Notify({ Title = "Lowrider Bounce", Content = "Lowrider Bounce enabled.", Duration = 3 })
            local wheels = getPlayerCarWheels()
            if not wheels then return end
            storeOriginalSprings()
            lowriderToggle = true
            cycleState = 0
            task.spawn(function()
                while lowriderToggle do
                    if cycleState == 0 then
                        animateWheelSet(getFrontWheels(), (originalSprings["FL"] and originalSprings["FL"].FreeLength or 0.8) + 0.5)
                        animateWheelSet(getFrontWheels(), (originalSprings["FR"] and originalSprings["FR"].FreeLength or 0.8) + 0.5)
                        cycleState = 1
                    elseif cycleState == 1 then
                        animateWheelSet(getFrontWheels(), (originalSprings["FL"] and originalSprings["FL"].FreeLength or 0.8) - 0.3)
                        animateWheelSet(getFrontWheels(), (originalSprings["FR"] and originalSprings["FR"].FreeLength or 0.8) - 0.3)
                        cycleState = 2
                    elseif cycleState == 2 then
                        animateWheelSet(getFrontWheels(), (originalSprings["FL"] and originalSprings["FL"].FreeLength or 0.8) + 0.5)
                        animateWheelSet(getFrontWheels(), (originalSprings["FR"] and originalSprings["FR"].FreeLength or 0.8) + 0.5)
                        cycleState = 1
                    end
                    task.wait(0.5)
                end
                animateToOriginal()
            end)
        else
            Notify({ Title = "Lowrider Bounce", Content = "Lowrider Bounce disabled.", Duration = 3 })
            lowriderToggle = false
            animateToOriginal()
        end
    end,
})

