local function updateCollisions()
    local body = getVehicleBody()
    if not body then return end
    for _, part in ipairs(body:GetDescendants()) do
        if part:IsA("BasePart") then
            if sumoEnabled then
                if collisionCache[part] == nil then collisionCache[part] = part.CanCollide end
                part.CanCollide = false
            else
                if collisionCache[part] ~= nil then part.CanCollide = collisionCache[part] end
            end
        end
    end
    if not sumoEnabled then collisionCache = {} end
end

