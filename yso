local function GetCash()
    local ls=LocalPlayer:FindFirstChild("leaderstats")
    if ls and ls:FindFirstChild("Cash") then return ls.Cash.Value end
    return 0
end

local function TeleportNearATM(attachment)
    local char=LocalPlayer.Character if not char then return end
    local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp then return end
    local atmPos=attachment.WorldPosition
    hrp.CFrame=CFrame.new(atmPos.X, atmPos.Y+3, atmPos.Z)
end

local function StopATMFarm()
    ATMRunning=false
    if ATMThread then task.cancel(ATMThread) ATMThread=nil end
    Notify("ATM Farm","Stopped.",3)
end

local function RunATMPass(loop)
    local atms=GetATMData()
    if #atms==0 then Notify("ATM Farm","No ATMs found!",4) ATMRunning=false return end
    local startCash=GetCash() local cycle=0
    while ATMRunning or (not loop) do
        cycle=cycle+1
        for _,data in ipairs(atms) do
            if not ATMRunning and loop then break end
            if ATMTeleport then TeleportNearATM(data.attachment) task.wait(0.3) end
            pcall(function() fireproximityprompt(data.prompt) end)
            task.wait(ATMDelay)
        end
        local gained=math.floor(GetCash()-startCash)
        Notify("ATM Farm — Cycle "..cycle,"+$"..gained.." | Balance: $"..math.floor(GetCash()),3)
        if not loop then break end
        task.wait(0.5)
    end
    ATMRunning=false
end

